{
  "envId": "quizmiao",
  "version": "1.1.0",
  "functions": [
    {
      "name": "quiz-generate",
      "timeout": 60,
      "env": {
        "DEEPSEEK_API_KEY": "",
        "DEEPSEEK_MODEL": "deepseek-v4-flash"
      }
    },
    {
      "name": "page-fetch",
      "timeout": 15
    },
    {
      "name": "share-manage",
      "timeout": 10
    },
    {
      "name": "history-manage",
      "timeout": 10
    },
    {
      "name": "share-result",
      "timeout": 10
    },
    {
      "name": "profile-manage",
      "timeout": 10
    }
  ],
  "collections": [
    {
      "name": "users",
      "permissions": {
        "read": false,
        "write": false
      }
    },
    {
      "name": "quiz_history",
      "permissions": {
        "read": false,
        "write": false
      }
    },
    {
      "name": "quiz_attempts",
      "permissions": {
        "read": false,
        "write": false
      }
    },
    {
      "name": "shares",
      "permissions": {
        "read": false,
        "write": false
      }
    },
    {
      "name": "share_results",
      "permissions": {
        "read": false,
        "write": false
      }
    }
  ],
  "indexes": [
    { "collection": "users", "fields": ["owner_id"] },
    { "collection": "quiz_history", "fields": ["owner_id", "created_at"] },
    { "collection": "quiz_attempts", "fields": ["owner_id", "history_id", "created_at"] },
    { "collection": "quiz_attempts", "fields": ["owner_id", "attempt_id"] },
    { "collection": "shares", "fields": ["owner_id", "created_at"] },
    { "collection": "share_results", "fields": ["share_id", "sharer_id", "created_at"] },
    { "collection": "share_results", "fields": ["share_id", "attempt_id"] }
  ]
}
